{"type":"wb","version":2,"source":"https://www.iodraw.com","elements":[{"id":"KFrN95JG6wbMIxpGvea1K","type":"rectangle","x":384,"y":217,"width":1350,"height":732,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":276117676,"version":82,"versionNonce":674440596,"isDeleted":false,"boundElements":null,"updated":1784077896483,"link":null},{"id":"cOz7qF031UqBEHhf7N8SK","type":"text","x":429.8333333333333,"y":244,"width":141,"height":40,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1049240236,"version":9,"versionNonce":1782168468,"isDeleted":false,"boundElements":null,"updated":1784077896483,"link":null,"text":"信息化平台","fontSize":28,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":30,"containerId":null,"originalText":"信息化平台"},{"id":"wQrn5pb8U-u1lYmP44oTU","type":"text","x":398.8333333333333,"y":309,"width":882,"height":104,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1095074220,"version":239,"versionNonce":2099407764,"isDeleted":false,"boundElements":null,"updated":1784077965711,"link":null,"text":"OA平台，信息传播，工作流程的建立\nNC主要是城东各个不同仓库（包括瓶盖、瓶子、包装盒以及手提袋）那边的生成的入库单\nU8主要是财务系统需要审计发来的发票和开具发票\n友空间类似于ERP系统，具有各个经销商的联络方式，还有一个图片审查系统，由销售公司进行使用","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":99,"containerId":null,"originalText":"OA平台，信息传播，工作流程的建立\nNC主要是城东各个不同仓库（包括瓶盖、瓶子、包装盒以及手提袋）那边的生成的入库单\nU8主要是财务系统需要审计发来的发票和开具发票\n友空间类似于ERP系统，具有各个经销商的联络方式，还有一个图片审查系统，由销售公司进行使用"},{"id":"AoV2jyNTv-ySCabNdcMu_","type":"text","x":393.5034965034965,"y":492.2424242424243,"width":1400,"height":257,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":32782124,"version":399,"versionNonce":208754708,"isDeleted":false,"boundElements":null,"updated":1784078224673,"link":null,"text":"运行的逻辑是三单匹配（订单，入库单，发票）\n分为俩类，一类是购入方，另一类是销售方\n作为购入方时，物品包括粮食、酒的容器以及促销品，涉及的部门包括采购中心的下订单，由各个仓库收到物品，采购数量核对后，生成入库单，最后由财务部\n完最后的校验，交易达成\n同样，并不是所有都有三个单据都有的，比如销售公司的出差报销，可能是直接发票，中间有个酒店或饭店的消费小票，起到入库单的作用，入库单\n在三单中起到一个核对证明的作用\n作为销售方\n当前公司最大的销售是酒，酒本身不是直接卖给下面门店而是卖给全国的经销商，再分销到各个门店以及饭店\n后续公司为促销，推出“”\n     ","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":252,"containerId":null,"originalText":"运行的逻辑是三单匹配（订单，入库单，发票）\n分为俩类，一类是购入方，另一类是销售方\n作为购入方时，物品包括粮食、酒的容器以及促销品，涉及的部门包括采购中心的下订单，由各个仓库收到物品，采购数量核对后，生成入库单，最后由财务部\n完最后的校验，交易达成\n同样，并不是所有都有三个单据都有的，比如销售公司的出差报销，可能是直接发票，中间有个酒店或饭店的消费小票，起到入库单的作用，入库单\n在三单中起到一个核对证明的作用\n作为销售方\n当前公司最大的销售是酒，酒本身不是直接卖给下面门店而是卖给全国的经销商，再分销到各个门店以及饭店\n后续公司为促销，推出“”\n     "},{"id":"5qjiUCrG43IdUZytloLg8","type":"text","x":396.43939393939405,"y":441.4242424242425,"width":281,"height":37,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":780202924,"version":48,"versionNonce":1276115628,"isDeleted":false,"boundElements":null,"updated":1784078159422,"link":null,"text":"核心逻辑——三单匹配","fontSize":28,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":30,"containerId":null,"originalText":"核心逻辑——三单匹配"}],"appState":{"theme":"light","currentChartType":"bar","currentItemBackgroundColor":"transparent","currentItemEndArrowhead":"arrow","currentItemFillStyle":"hachure","currentItemFontFamily":2,"currentItemFontSize":20,"currentItemLinearStrokeSharpness":"round","currentItemOpacity":100,"currentItemRoughness":1,"currentItemStartArrowhead":null,"currentItemStrokeColor":"#000000","currentItemStrokeSharpness":"sharp","currentItemStrokeStyle":"solid","currentItemStrokeWidth":1,"currentItemTextAlign":"left","cursorButton":"up","editingGroupId":null,"elementLocked":false,"elementType":"selection","exportBackground":true,"exportScale":1,"exportEmbedScene":false,"exportWithDarkMode":false,"gridSize":null,"lastPointerDownWith":"mouse","name":"Untitled-2026-07-15-0844","openMenu":null,"previousSelectedElementIds":{"AoV2jyNTv-ySCabNdcMu_":true,"L6GyomM-XZTn3WKLpckWh":true},"scrolledOutside":false,"scrollX":21.068181818181756,"scrollY":-252.7406759906759,"selectedElementIds":{},"selectedGroupIds":{},"shouldCacheIgnoreZoom":false,"showStats":false,"viewBackgroundColor":"#ffffff","zenModeEnabled":false,"zoom":{"value":1.1}},"files":{}}