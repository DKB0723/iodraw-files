{"type":"wb","version":2,"source":"https://www.iodraw.com","elements":[{"id":"KFrN95JG6wbMIxpGvea1K","type":"rectangle","x":384,"y":217,"width":1350,"height":732,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":276117676,"version":81,"versionNonce":2108727188,"isDeleted":false,"boundElements":null,"updated":1784076349049,"link":null},{"id":"cOz7qF031UqBEHhf7N8SK","type":"text","x":429.8333333333333,"y":244,"width":141,"height":40,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1049240236,"version":8,"versionNonce":713787948,"isDeleted":false,"boundElements":null,"updated":1784077222489,"link":null,"text":"信息化平台","fontSize":28,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":30,"containerId":null,"originalText":"信息化平台"},{"id":"wQrn5pb8U-u1lYmP44oTU","type":"text","x":428.8333333333333,"y":307,"width":882,"height":104,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1095074220,"version":217,"versionNonce":434931372,"isDeleted":false,"boundElements":null,"updated":1784077198502,"link":null,"text":"OA平台，信息传播，工作流程的建立\nNC主要是城东各个不同仓库（包括瓶盖、瓶子、包装盒以及手提袋）那边的生成的入库单\nU8主要是财务系统需要审计发来的发票和开具发票\n友空间类似于ERP系统，具有各个经销商的联络方式，还有一个图片审查系统，由销售公司进行使用","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":99,"containerId":null,"originalText":"OA平台，信息传播，工作流程的建立\nNC主要是城东各个不同仓库（包括瓶盖、瓶子、包装盒以及手提袋）那边的生成的入库单\nU8主要是财务系统需要审计发来的发票和开具发票\n友空间类似于ERP系统，具有各个经销商的联络方式，还有一个图片审查系统，由销售公司进行使用"},{"id":"AoV2jyNTv-ySCabNdcMu_","type":"text","x":428,"y":493.3333333333333,"width":1300,"height":205,"angle":0,"strokeColor":"#e67700","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":32782124,"version":299,"versionNonce":460146708,"isDeleted":false,"boundElements":null,"updated":1784077891868,"link":null,"text":"运行的逻辑是三单匹配（订单，入库单，发票）\n分为俩类，一类是购入方，另一类是销售方\n作为购入方时，物品包括粮食和酒的容器，涉及的部门包括采购中心的下订单，由各个仓库收到物品，采购数量核对后，生成入库单，最后由财务部\n完最后的校验，交易达成\n同样，并不是所有都有三个单据都有的，比如销售公司的出差报销，可能是直接发票，中间有个酒店或饭店的消费小票，起到入库单的作用，入库单\n在三单中起到一个核对证明的作用\n作为销售方\n","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":200,"containerId":null,"originalText":"运行的逻辑是三单匹配（订单，入库单，发票）\n分为俩类，一类是购入方，另一类是销售方\n作为购入方时，物品包括粮食和酒的容器，涉及的部门包括采购中心的下订单，由各个仓库收到物品，采购数量核对后，生成入库单，最后由财务部\n完最后的校验，交易达成\n同样，并不是所有都有三个单据都有的，比如销售公司的出差报销，可能是直接发票，中间有个酒店或饭店的消费小票，起到入库单的作用，入库单\n在三单中起到一个核对证明的作用\n作为销售方\n"},{"id":"5qjiUCrG43IdUZytloLg8","type":"text","x":419.1666666666668,"y":442.33333333333337,"width":281,"height":37,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":780202924,"version":28,"versionNonce":1512317100,"isDeleted":false,"boundElements":null,"updated":1784077265435,"link":null,"text":"核心逻辑——三单匹配","fontSize":28,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":30,"containerId":null,"originalText":"核心逻辑——三单匹配"}],"appState":{"theme":"light","currentChartType":"bar","currentItemBackgroundColor":"transparent","currentItemEndArrowhead":"arrow","currentItemFillStyle":"hachure","currentItemFontFamily":2,"currentItemFontSize":20,"currentItemLinearStrokeSharpness":"round","currentItemOpacity":100,"currentItemRoughness":1,"currentItemStartArrowhead":null,"currentItemStrokeColor":"#e67700","currentItemStrokeSharpness":"sharp","currentItemStrokeStyle":"solid","currentItemStrokeWidth":1,"currentItemTextAlign":"left","cursorButton":"up","editingGroupId":null,"elementLocked":false,"elementType":"selection","exportBackground":true,"exportScale":1,"exportEmbedScene":false,"exportWithDarkMode":false,"gridSize":null,"lastPointerDownWith":"mouse","name":"Untitled-2026-07-15-0844","openMenu":null,"previousSelectedElementIds":{"AoV2jyNTv-ySCabNdcMu_":true,"4hVvCKcOmgZjvghJ4WYOD":true},"scrolledOutside":false,"scrollX":-158.33333333333348,"scrollY":-78.16666666666674,"selectedElementIds":{},"selectedGroupIds":{},"shouldCacheIgnoreZoom":false,"showStats":false,"viewBackgroundColor":"#ffffff","zenModeEnabled":false,"zoom":{"value":1.2000000000000002}},"files":{}}