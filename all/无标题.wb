{"type":"wb","version":2,"source":"https://www.iodraw.com","elements":[{"id":"KFrN95JG6wbMIxpGvea1K","type":"rectangle","x":384,"y":217,"width":1350,"height":732,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":276117676,"version":81,"versionNonce":2108727188,"isDeleted":false,"boundElements":null,"updated":1784076349049,"link":null},{"id":"cOz7qF031UqBEHhf7N8SK","type":"text","x":429.8333333333333,"y":244,"width":85,"height":40,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1049240236,"version":7,"versionNonce":547147180,"isDeleted":false,"boundElements":null,"updated":1784076774125,"link":null,"text":"信息化","fontSize":28,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":30,"containerId":null,"originalText":"信息化"},{"id":"wQrn5pb8U-u1lYmP44oTU","type":"text","x":428.8333333333333,"y":307,"width":882,"height":130,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1095074220,"version":209,"versionNonce":1922512812,"isDeleted":false,"boundElements":null,"updated":1784077113382,"link":null,"text":"OA平台，信息传播，工作流程的建立\n采购中心应该会有订单生成\nNC主要是城东各个不同仓库（包括瓶盖、瓶子、包装盒以及手提袋）那边的生成的入库单\nU8主要是财务系统需要审计发来的发票，以及开具一些发票\n友空间类似于ERP系统，具有各个经销商的联络方式，还有一个图片审查系统，由销售公司进行使用","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":125,"containerId":null,"originalText":"OA平台，信息传播，工作流程的建立\n采购中心应该会有订单生成\nNC主要是城东各个不同仓库（包括瓶盖、瓶子、包装盒以及手提袋）那边的生成的入库单\nU8主要是财务系统需要审计发来的发票，以及开具一些发票\n友空间类似于ERP系统，具有各个经销商的联络方式，还有一个图片审查系统，由销售公司进行使用"},{"id":"AoV2jyNTv-ySCabNdcMu_","type":"text","x":428.00000000000006,"y":494.1666666666667,"width":520,"height":101,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":32782124,"version":177,"versionNonce":1277259180,"isDeleted":false,"boundElements":null,"updated":1784077093590,"link":null,"text":"运行的逻辑是三单匹配（订单，入库单，发票）\n分为俩类，一类是购入方，另一类是销售方\n作为购入方时，涉及的部门包括采购中心的下订单，入库单\n","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":96,"containerId":null,"originalText":"运行的逻辑是三单匹配（订单，入库单，发票）\n分为俩类，一类是购入方，另一类是销售方\n作为购入方时，涉及的部门包括采购中心的下订单，入库单\n"}],"appState":{"theme":"light","currentChartType":"bar","currentItemBackgroundColor":"transparent","currentItemEndArrowhead":"arrow","currentItemFillStyle":"hachure","currentItemFontFamily":2,"currentItemFontSize":28,"currentItemLinearStrokeSharpness":"round","currentItemOpacity":100,"currentItemRoughness":1,"currentItemStartArrowhead":null,"currentItemStrokeColor":"#000000","currentItemStrokeSharpness":"sharp","currentItemStrokeStyle":"solid","currentItemStrokeWidth":1,"currentItemTextAlign":"left","cursorButton":"up","editingGroupId":null,"elementLocked":false,"elementType":"selection","exportBackground":true,"exportScale":1,"exportEmbedScene":false,"exportWithDarkMode":false,"gridSize":null,"lastPointerDownWith":"mouse","name":"Untitled-2026-07-15-0844","openMenu":null,"previousSelectedElementIds":{"wQrn5pb8U-u1lYmP44oTU":true},"scrolledOutside":false,"scrollX":-158.33333333333348,"scrollY":-78.16666666666674,"selectedElementIds":{},"selectedGroupIds":{},"shouldCacheIgnoreZoom":false,"showStats":false,"viewBackgroundColor":"#ffffff","zenModeEnabled":false,"zoom":{"value":1.2000000000000002}},"files":{}}