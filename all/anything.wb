{"type":"wb","version":2,"source":"https://www.iodraw.com","elements":[{"type":"rectangle","version":258,"versionNonce":1245147796,"isDeleted":false,"id":"KFrN95JG6wbMIxpGvea1K","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":372.98989898989885,"y":217,"strokeColor":"#000000","backgroundColor":"transparent","width":1361.0101010101012,"height":593.8253968253969,"seed":276117676,"groupIds":[],"strokeSharpness":"sharp","boundElements":[],"updated":1784080547952,"link":null},{"type":"text","version":26,"versionNonce":802862100,"isDeleted":false,"id":"cOz7qF031UqBEHhf7N8SK","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":401.6515151515151,"y":241.27272727272725,"strokeColor":"#000000","backgroundColor":"transparent","width":141,"height":40,"seed":1049240236,"groupIds":[],"strokeSharpness":"sharp","boundElements":[],"updated":1784079816640,"link":null,"fontSize":28,"fontFamily":1,"text":"信息化平台","baseline":30,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"信息化平台"},{"type":"text","version":305,"versionNonce":521581076,"isDeleted":false,"id":"wQrn5pb8U-u1lYmP44oTU","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":398.83333333333326,"y":294.45454545454544,"strokeColor":"#000000","backgroundColor":"transparent","width":881,"height":130,"seed":1095074220,"groupIds":[],"strokeSharpness":"sharp","boundElements":[],"updated":1784079745075,"link":null,"fontSize":20,"fontFamily":2,"text":"OA平台，信息传播，工作流程的建立\nNC主要是城东各个不同仓库（包括瓶盖、瓶子、包装盒以及手提袋）那边的生成的入库单\nU8主要是财务系统需要审计发来的发票和开具发票\n友空间类似于ERP系统，具有各个经销商的联络方式，还有一个图片审查系统，由销售公司进行使用\n兆信作为二维码专精公司，主要功能有防伪和管理物流信息，后续做的小程序还有一些酒上面的活动","baseline":125,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"OA平台，信息传播，工作流程的建立\nNC主要是城东各个不同仓库（包括瓶盖、瓶子、包装盒以及手提袋）那边的生成的入库单\nU8主要是财务系统需要审计发来的发票和开具发票\n友空间类似于ERP系统，具有各个经销商的联络方式，还有一个图片审查系统，由销售公司进行使用\n兆信作为二维码专精公司，主要功能有防伪和管理物流信息，后续做的小程序还有一些酒上面的活动"},{"type":"text","version":523,"versionNonce":1009661125,"isDeleted":false,"id":"AoV2jyNTv-ySCabNdcMu_","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":397.2307692307692,"y":482.3333333333334,"strokeColor":"#000000","backgroundColor":"transparent","width":1300,"height":309,"seed":32782124,"groupIds":[],"strokeSharpness":"sharp","boundElements":[],"updated":1784252735423,"link":null,"fontSize":20,"fontFamily":2,"text":"运行的逻辑是三单匹配（订单，入库单，发票）\n分为俩类，一类是购入方，另一类是销售方\n作为购入方时，物品包括粮食、酒的容器以及促销品等等\n涉及的部门包括采购中心的下订单，由各个仓库收到物品，采购数量核对后，生成入库单，最后由财务部\n完最后的校验，交易达成\n同样，并不是所有都有三个单据都有的，比如销售公司的出差报销，可能是直接发票，中间有个酒店或饭店的消费小票，起到入库单的作用，入库单\n在三单中起到一个证明的作用\n作为销售方\n当前公司最大的销售是酒，酒本身不是直接卖给下面门店而是卖给全国的经销商，再分销到各个门店以及饭店\n后续公司为促销，推出“云豆”，本质上也是一种商品，是一种电子商品，要通过发票确定其合法性，通过物流系统对数量精准控制\nOA在中间起到任务信息的传递\n","baseline":304,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"运行的逻辑是三单匹配（订单，入库单，发票）\n分为俩类，一类是购入方，另一类是销售方\n作为购入方时，物品包括粮食、酒的容器以及促销品等等\n涉及的部门包括采购中心的下订单，由各个仓库收到物品，采购数量核对后，生成入库单，最后由财务部\n完最后的校验，交易达成\n同样，并不是所有都有三个单据都有的，比如销售公司的出差报销，可能是直接发票，中间有个酒店或饭店的消费小票，起到入库单的作用，入库单\n在三单中起到一个证明的作用\n作为销售方\n当前公司最大的销售是酒，酒本身不是直接卖给下面门店而是卖给全国的经销商，再分销到各个门店以及饭店\n后续公司为促销，推出“云豆”，本质上也是一种商品，是一种电子商品，要通过发票确定其合法性，通过物流系统对数量精准控制\nOA在中间起到任务信息的传递\n"},{"type":"text","version":48,"versionNonce":1276115628,"isDeleted":false,"id":"5qjiUCrG43IdUZytloLg8","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":396.43939393939405,"y":441.4242424242425,"strokeColor":"#000000","backgroundColor":"transparent","width":281,"height":37,"seed":780202924,"groupIds":[],"strokeSharpness":"sharp","boundElements":[],"updated":1784078159422,"link":null,"fontSize":28,"fontFamily":2,"text":"核心逻辑——三单匹配","baseline":30,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"核心逻辑——三单匹配"},{"id":"VcjIMgOBqk51MWh1W_WGD","type":"rectangle","x":365.4949494949494,"y":872.4126984126984,"width":1371,"height":655.9999999999999,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":210773515,"version":180,"versionNonce":837539051,"isDeleted":false,"boundElements":null,"updated":1784253195202,"link":null},{"id":"UrRwaKasW5T4C-jbGTyN2","type":"text","x":420.4949494949494,"y":886.9126984126984,"width":197,"height":37,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":679360709,"version":9,"versionNonce":1988108549,"isDeleted":false,"boundElements":null,"updated":1784253219143,"link":null,"text":"关于工作的开展","fontSize":28,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":30,"containerId":null,"originalText":"关于工作的开展"},{"id":"XFDJOcv5A26oEmaJwfBsa","type":"text","x":437.4949494949494,"y":935.9126984126984,"width":560,"height":111,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":702377509,"version":25,"versionNonce":33782955,"isDeleted":false,"boundElements":null,"updated":1784253300581,"link":null,"text":"内部小组，懂业务的高管牵头，各个其他部门\n需求清单\n需要dome，且能适用","fontSize":28,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":104,"containerId":null,"originalText":"内部小组，懂业务的高管牵头，各个其他部门\n需求清单\n需要dome，且能适用"},{"id":"KVJOgk4OAY9FX4VsW3Z5t","type":"text","x":442.4949494949494,"y":1074.9126984126983,"width":196,"height":148,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":173558181,"version":19,"versionNonce":1806263749,"isDeleted":false,"boundElements":null,"updated":1784253530343,"link":null,"text":"适用性和冗余\n全周期的成本\n数据安全与服务\n长期的扩展性","fontSize":28,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":141,"containerId":null,"originalText":"适用性和冗余\n全周期的成本\n数据安全与服务\n长期的扩展性"}],"appState":{"theme":"light","currentChartType":"bar","currentItemBackgroundColor":"transparent","currentItemEndArrowhead":"arrow","currentItemFillStyle":"hachure","currentItemFontFamily":2,"currentItemFontSize":28,"currentItemLinearStrokeSharpness":"round","currentItemOpacity":100,"currentItemRoughness":1,"currentItemStartArrowhead":null,"currentItemStrokeColor":"#000000","currentItemStrokeSharpness":"sharp","currentItemStrokeStyle":"solid","currentItemStrokeWidth":1,"currentItemTextAlign":"left","cursorButton":"up","editingGroupId":null,"elementLocked":false,"elementType":"selection","exportBackground":true,"exportScale":1,"exportEmbedScene":false,"exportWithDarkMode":false,"gridSize":null,"lastPointerDownWith":"mouse","name":"Untitled-2026-07-15-0844","openMenu":null,"previousSelectedElementIds":{"KVJOgk4OAY9FX4VsW3Z5t":true,"jEV3mk1hdgVuxlgnTImNN":true},"scrolledOutside":false,"scrollX":-97.49494949494942,"scrollY":-533.4126984126984,"selectedElementIds":{},"selectedGroupIds":{},"shouldCacheIgnoreZoom":false,"showStats":false,"viewBackgroundColor":"#ffffff","zenModeEnabled":false,"zoom":{"value":1}},"files":{}}